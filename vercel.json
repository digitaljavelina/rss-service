{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build:css",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/cron/scheduler.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/scheduler",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
