# RSS Service - Docker Environment Configuration
# Copy this file to .env.docker and customize as needed

# ============================================================================
# PostgreSQL
# ============================================================================

# Database connection (constructed automatically in docker-compose.yml)
# Only set this if you're connecting to an external PostgreSQL instance
# DATABASE_URL=postgresql://rssuser:rsspassword@postgres:5432/rssservice

# PostgreSQL password (change this in production!)
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ============================================================================
# Application
# ============================================================================

# Node environment (set in Dockerfile, override here if needed)
# NODE_ENV=production

# Internal container port (usually no need to change)
# PORT=3000

# Public URL of your RSS Service instance
# Used for generating feed URLs in the UI and API responses
# IMPORTANT: Set this to your reverse proxy URL if using one (e.g., Caddy, nginx)
# BASE_URL=https://rss.example.com
BASE_URL=http://localhost:3000

# ============================================================================
# Port Mapping
# ============================================================================

# Host port that maps to container port 3000
# Change this if port 3000 is already in use on your host
APP_PORT=3000

# ============================================================================
# Chromium (set in Dockerfile, usually no need to override)
# ============================================================================

# Path to system Chromium binary (set automatically in Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ============================================================================
# Optional: External Services
# ============================================================================

# YouTube Data API key (for enhanced YouTube feed extraction)
# YOUTUBE_API_KEY=your_youtube_api_key_here

